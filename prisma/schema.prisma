generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id Int @id @default(autoincrement())
  email String @unique
  name String?
  loans Loan[]
}

model Item {
  id Int @id @default(autoincrement())
  name String
  category String?
  totalQuantity Int
  location String
  loans Loan[]
}

model Loan {
  id Int @id @default(autoincrement())

  loanDate DateTime @default(now())
  dueDate DateTime 
  returnDate DateTime?

  user User @relation(fields: [userId], references: [id])
  userId Int

  item Item @relation(fields: [itemId], references: [id])
  itemId Int
}